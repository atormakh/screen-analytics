{
  "identifier": "default",
  "description": "Default capabilities for Screenly",
  "windows": ["main"],
  "remote": {
    "urls": [
      "http://localhost:1420",
      "http://localhost:1420/*",
      "http://127.0.0.1:1420",
      "http://127.0.0.1:1420/*"
    ]
  },
  "permissions": [
    "core:default",
    "core:event:default",
    "fs:default",
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "$APPDATA/**" }]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "$APPDATA/**" }]
    }
  ]
}
