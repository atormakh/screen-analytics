# Vercel AI Gateway (OpenAI-compatible). Get a key in the Vercel dashboard.
PUBLIC_AI_GATEWAY_API_KEY=
# Optional (defaults shown):
# PUBLIC_AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
# Vision + text defaults in code: google/gemini-3-flash (lightweight). Examples:
# PUBLIC_AI_GATEWAY_MODEL_VISION=google/gemini-3-flash
# PUBLIC_AI_GATEWAY_MODEL_TEXT=google/gemini-3-flash
# PUBLIC_AI_GATEWAY_MODEL_VISION=openai/gpt-4o-mini
# PUBLIC_AI_GATEWAY_MODEL_TEXT=openai/gpt-4o-mini

PUBLIC_NOTION_API_KEY=
PUBLIC_NOTION_DB_ID=
# Optional: exact Notion column names if yours differ from the defaults
# PUBLIC_NOTION_PROP_NAME=Name
# PUBLIC_NOTION_PROP_SUMMARY=Summary
# PUBLIC_NOTION_PROP_TIMESTAMP=Timestamp
# PUBLIC_NOTION_PROP_PATH=Path
# PUBLIC_NOTION_PROP_TAGS=Tags
# If you have no Tags column: PUBLIC_NOTION_SKIP_TAGS=1
